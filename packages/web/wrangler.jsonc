{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sce-web",
  "compatibility_date": "2026-07-14",
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "sce-web.pasttime.xyz", "zone_name": "pasttime.xyz" }
  ],
  "assets": {
    "directory": "frontend"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
