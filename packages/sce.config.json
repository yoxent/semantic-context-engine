{
  "embedding": {
    "provider": "openai-compatible",
    "baseUrl": "https://openrouter.ai/api/v1",
    "model": "nvidia/llama-nemotron-embed-vl-1b-v2:free",
    "dimensions": 2048,
    "batchSize": 1,
    "apiKeyEnv": "OPENROUTER_API_KEY"
  },
  "indexing": {
    "include": ["**/*.ts", "**/*.md"],
    "ignore": [
      "**/__tests__/**",
      "**/*.test.ts",
      "**/*.spec.ts",
      "**/dist/**",
      "**/node_modules/**"
    ]
  }
}
